{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SMAL: diagram",
            "type": "debugpy",
            "request": "launch",
            "module": "smal.cli.app",
            "cwd": "${workspaceFolder}/src",
            "args": [
                "diagram",
                "${workspaceFolder}/src/examples/example.smal",
                "${workspaceFolder}/src/examples",
                "-f"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "SMAL: code (builtin)",
            "type": "debugpy",
            "request": "launch",
            "module": "smal.cli.app",
            "cwd": "${workspaceFolder}/src",
            "args": [
                "code",
                "${workspaceFolder}/src/examples/example.smal",
                "-t",
                "c-machine-hdr",
                "-f"
            ],
            "console": "integratedTerminal"
        },
    ]
}